# Copier en .env et remplir. NE JAMAIS commiter .env.
# Note : les MCP (FullEnrich, Sillage, Folk) se connectent en OAuth (login navigateur) ->
# les *_API_KEY ci-dessous ne servent QUE si tu passes par l'API REST au lieu du MCP.

# --- Claude (Agent SDK) : REQUIS ---
ANTHROPIC_API_KEY=

# --- Microsoft Graph via NextAuth (Azure AD) : REQUIS (agenda + drafts) ---
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common          # "common" = comptes perso+org (evite l'admin consent en demo)
NEXTAUTH_SECRET=                    # generer : openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000 # en prod : l'URL Vercel

# --- FullEnrich : REQUIS (REST) ou via MCP (OAuth, sans cle) ---
FULLENRICH_API_KEY=
FULLENRICH_WEBHOOK_URL=            # optionnel : URL publique pour recevoir les resultats d'enrich (sinon polling)

# --- Sillage : via MCP (OAuth, sans cle). Cle REST optionnelle (sk_live_...) ---
SILLAGE_API_KEY=

# --- Google Maps (geocode / places, pour les voisins) ---
GOOGLE_MAPS_API_KEY=

# --- Gradium (TTS fiche audio) - code promo GTM-HACK ---
GRADIUM_API_KEY=

# --- Folk (CRM warm) : DIFFERE (si le temps). MCP OAuth, cle REST optionnelle ---
FOLK_API_KEY=

# Rappel : API Gouv recherche-entreprises = gratuite, PAS de cle.
